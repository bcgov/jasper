{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Information",
      "Scv.TdApi": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "https://common-sso.justice.gov.bc.ca/auth/realms/Judiciary",
    "Audience": "TD-Dev",
    "ClientId": "TD-Dev",
    "QueryRole": "query",
    "ReadRole": "read",
    "ValidateIssuer": true,
    "RequireHttpsMetadata": true
  },
  "CorrectionMappings": {
    "RegionMappings": [
      {
        "Target": "Fraser",
        "Replacement": "Fraser+Vancouver Coastal"
      },
      {
        "Target": "Vancouver",
        "Replacement": "Fraser+Vancouver Coastal"
      }
    ], // Use regionmappings to remap PCSS/JC region names to region names used in P/Q drive. Case sensitive.
    "LocationMappings": [
      {
        "Target": "222-Main",
        "Replacement": "222 main"
      }
    ] // Use locationmappings to remap PCSS/JC location names to location names used in P/Q drive. Case sensitive.
  },
    "SharedDrive": {
      "FileSystemType": "SmbFileSystem",
      "BasePath": "Criminal Share",
      "SmbServer": "alexandria.provjud.local",
      "SmbShareName": "Province",
      "SmbUsername": "USE_SECRETS",
      "SmbPassword": "USE_SECRETS",
      "SmbDomain": "PROVJUD",
      "DateFolderFormats": [
        "yyyy/MM MMMM/MMMM d (ddd)"
      ], // Allows for multiple date folder formats in cases of inconsistent folder structures
      "MaxRetryAttempts": 3,
      "InitialRetryDelayMs": 1000,
      "RoomTraversalMaxConcurrency": 4
    },
    "SplunkCollectorUrl": "https://splunk.example.com/services/collector",
    "SplunkToken": "USE_SECRETS"
  }
